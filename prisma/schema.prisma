generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum UserRole {
  ADMIN
  EMPLOYEE
}

enum TimeEntryStatus {
  DRAFT
  APPROVED
  LOCKED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          UserRole @default(EMPLOYEE)
  employeeId    String?  @unique
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdTimeEntries	TimeEntry[] @relation("TimeEntryCreatedBy")
}

model Employee {
  id               String   @id @default(cuid())
  legalName        String
  preferredName    String?
  email            String   @unique
  hourlyRateCents  Int      @default(0)
  active           Boolean  @default(true)
  startDate        DateTime?
  user             User?
  timeEntries      TimeEntry[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TimeEntry {
  id            String          @id @default(cuid())
  employeeId    String
  employee      Employee        @relation(fields: [employeeId], references: [id])
  workDate      DateTime
  startTime     DateTime?
  endTime       DateTime?
  minutesWorked Int             @default(0)  // optional: store computed minutes for simplicity
  breakMinutes  Int             @default(0)
  notes         String?
  status        TimeEntryStatus @default(DRAFT)
  createdById   String?
  createdBy     User?           @relation("TimeEntryCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([employeeId, workDate])
}
