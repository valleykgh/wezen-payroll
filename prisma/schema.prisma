
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}
model Organization {
  id Int @id @default(autoincrement())
  name String
}
model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  role String
  organizationId Int
}
model Contractor {
  id Int @id @default(autoincrement())
  name String
  email String
  hourlyRate Float
  stripeAccountId String?
}
model Timesheet {
  id Int @id @default(autoincrement())
  contractorId Int
  hours Float
  approved Boolean @default(false)
  paid Boolean @default(false)
}
